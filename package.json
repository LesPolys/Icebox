{
  "name": "icebox",
  "version": "0.1.0",
  "private": true,
  "description": "Generation ship deckbuilder card game",
  "workspaces": [
    "packages/shared",
    "packages/game",
    "packages/editor"
  ],
  "scripts": {
    "dev:game": "npm run dev -w packages/game",
    "dev:editor": "npm run dev -w packages/editor",
    "build:shared": "npm run build -w packages/shared",
    "build:game": "npm run build -w packages/game",
    "build:editor": "npm run build -w packages/editor",
    "build": "npm run build:shared && npm run build:game && npm run build:editor",
    "typecheck": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p packages/game/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
